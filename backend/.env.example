# ==============================================
# ChiliScan Backend Environment Configuration
# ==============================================

# MongoDB Configuration
# For local MongoDB:
# MONGODB_URL=mongodb://localhost:27017
# For MongoDB Atlas:
# MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=ChiliScan
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=chiliscan

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=chili-analyzer-images

# Redis Configuration (For Celery)
REDIS_URL=redis://localhost:6379/0

# Application Settings
DEBUG=True
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# CORS Settings
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File Upload Settings
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=["jpg","jpeg","png"]

# ML Model Paths
CNN_MODEL_PATH=ml/models/cnn_variety_classifier.h5
RF_MODEL_PATH=ml/models/random_forest_shu.joblib
DT_MODEL_PATH=ml/models/decision_tree_maturity.joblib
LR_MODEL_PATH=ml/models/linear_regression_shu.joblib

# ==============================================
# Roboflow Configuration (for chili classification)
# ==============================================
# Get your API key from: https://roboflow.com -> Settings -> API Key
ROBOFLOW_API_KEY=your-roboflow-api-key
ROBOFLOW_PROJECT_ID=your-project-id
ROBOFLOW_MODEL_VERSION=1
# Set to true for hosted API (recommended), false for local inference
ROBOFLOW_USE_HOSTED=true
