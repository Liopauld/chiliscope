# Environment Configuration
# Copy this file to .env and update the values

# MongoDB Configuration
MONGO_USERNAME=admin
MONGO_PASSWORD=your-secure-password-here

# Backend Configuration  
SECRET_KEY=your-very-long-and-secure-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Mongo Express (Admin UI)
MONGOEXPRESS_USER=admin
MONGOEXPRESS_PASSWORD=admin123

# Azure Storage (Optional)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=chili-images

# ML Model Configuration
MODEL_PATH=/app/models
VARIETY_MODEL_PATH=/app/models/variety_classifier.h5
HEAT_MODEL_PATH=/app/models/heat_predictor.pkl
MATURITY_MODEL_PATH=/app/models/maturity_predictor.pkl
